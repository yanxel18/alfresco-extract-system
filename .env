# Docker Compose environment — used by backend and worker containers
# For local dev (without Docker), edit backend/.env instead

# Alfresco PostgreSQL — host.docker.internal reaches the host machine from inside a container
ALFRESCO_DB_URL=postgresql://alfresco:alfresco@host.docker.internal:5432/alfresco

# Path to alf_data INSIDE the container (bind-mounted from host via ALF_DATA_HOST_PATH)
ALF_DATA_PATH=/alf_data

# Host path to alf_data — Docker Compose uses this to create the bind mount
ALF_DATA_HOST_PATH=D:/alfresco/acs-deployment/docker-compose/alf_data

# Local PostgreSQL job-tracking database (aes_tracking service)
LOCAL_DB_URL=postgresql://aes_user:aes_pass@local_db:5432/aes_tracking

# Redis — use the 'redis' service name (not localhost)
REDIS_URL=redis://redis:6379/0

# Export output (inside container, bind-mounted to ./exports on host)
EXPORT_DIR=/app/exports

# Alfresco REST API (optional, host.docker.internal for Docker)
ALFRESCO_API_URL=http://host.docker.internal:8080/alfresco
ALFRESCO_USER=admin
ALFRESCO_PASS=admin
