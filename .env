# Docker Compose environment — used by backend and worker containers
# For local dev (without Docker), edit backend/.env instead

# Alfresco PostgreSQL — direct IP of the Windows server running Alfresco
ALFRESCO_DB_URL=postgresql://alfresco:ITG646@172.31.12.119:5432/alfresco

# Path to alf_data INSIDE the container (bind-mounted from host via ALF_DATA_HOST_PATH)
ALF_DATA_PATH=/alf_data

# Host path to alf_data — map \\172.31.12.119\alf_data as a network drive (e.g. Z:) first
# Then set this to that drive letter path. Docker Desktop cannot use UNC paths directly.
ALF_DATA_HOST_PATH=Z:/

# Local PostgreSQL job-tracking database (aes_tracking service)
LOCAL_DB_URL=postgresql://aes_user:aes_pass@local_db:5432/aes_tracking

# Redis — use the 'redis' service name (not localhost)
REDIS_URL=redis://redis:6379/0

# Export output (inside container, bind-mounted to ./exports on host)
EXPORT_DIR=/app/exports

# Remote SMB-backed Alfresco contentstore is sensitive to parallel reads.
COPY_CONCURRENCY=1

# Alfresco REST API
ALFRESCO_API_URL=http://172.31.12.119:8080/alfresco
ALFRESCO_USER=admin
ALFRESCO_PASS=ITG646
