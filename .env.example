# Alfresco PostgreSQL (read-only connection)
ALFRESCO_DB_URL=postgresql://alfresco:alfresco@localhost:5432/alfresco

# Path to alf_data directory on the HOST machine (bind-mounted from Alfresco Docker container)
# Windows:
ALF_DATA_PATH=D:/alfresco/acs-deployment/docker-compose/alf_data
# Linux/Mac:
# ALF_DATA_PATH=/opt/alfresco/acs-deployment/docker-compose/alf_data

# Local SQLite database for job tracking (relative to backend/)
LOCAL_DB_URL=sqlite:///./job_tracking.db

# Redis broker for Celery background workers
REDIS_URL=redis://localhost:6379/0

# Output directory for extracted files and CSV (relative to backend/)
EXPORT_DIR=./exports

# Alfresco REST API (optional, used only for fallback operations)
ALFRESCO_API_URL=http://localhost:8080/alfresco
ALFRESCO_USER=admin
ALFRESCO_PASS=admin
