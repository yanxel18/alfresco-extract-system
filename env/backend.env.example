# ============================================================
# Alfresco Extract System — Backend Environment Variables
# Copy this file to env/backend.env and fill in your values.
# ============================================================

# --- Alfresco PostgreSQL (READ-ONLY) ---
# In Docker: use host.docker.internal to reach the host machine (Docker Desktop for Windows/Mac).
# On Linux Docker: use the host's LAN IP, or add extra_hosts: host-gateway to docker-compose.
# For dev (no Docker): use localhost.
ALFRESCO_DB_URL=postgresql://alfresco:alfresco@host.docker.internal:5432/alfresco

# --- Path to alf_data INSIDE the container ---
# In Docker: /alf_data  (bind-mounted via ALF_DATA_HOST_PATH in docker-compose.yml)
# Local dev (no Docker): set to the actual host path:
#   Windows: D:/alfresco/acs-deployment/docker-compose/alf_data
#   Linux:   /opt/alfresco/acs-deployment/docker-compose/alf_data
ALF_DATA_PATH=/alf_data

# --- Local PostgreSQL (job tracking database) ---
# In Docker: use service name "local_db". For dev: use localhost.
LOCAL_DB_URL=postgresql://aes_user:aes_pass@local_db:5432/aes_tracking

# --- Redis (Celery broker) ---
REDIS_URL=redis://redis:6379/0

# --- Export output directory (relative to backend/) ---
EXPORT_DIR=./exports

# --- Alfresco REST API (optional fallback) ---
ALFRESCO_API_URL=http://localhost:8080/alfresco
ALFRESCO_USER=admin
ALFRESCO_PASS=admin
