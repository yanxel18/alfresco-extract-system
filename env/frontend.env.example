# ============================================================
# Alfresco Extract System — Frontend Environment Variables
# Copy this file to frontend/.env.local for local development.
# In Docker, these are passed as build args (see docker-compose.yml).
# All variables must be prefixed with VITE_ to be exposed to the browser.
# ============================================================

# Backend API base URL. Leave empty to use the same origin (nginx proxy in Docker).
# For local dev with Vite proxy, this can be left empty or set to http://localhost:8000
VITE_API_BASE_URL=

# Application display name
VITE_APP_NAME=Alfresco Extract System
