# ============================================================
# Alfresco Extract System — Backend Environment Variables
# Copy this file to env/backend.env and fill in your values.
# ============================================================

# --- Alfresco PostgreSQL (READ-ONLY) ---
# In Docker: use host.docker.internal to reach the host machine.
# For dev (no Docker): use localhost.
ALFRESCO_DB_URL=postgresql://alfresco:ITG646@172.31.12.119:5432/alfresco

# --- Path to alf_data INSIDE the container ---
# The host path is bind-mounted to /alf_data in docker-compose.yml.
# For local dev (no Docker): set this to the actual host path, e.g.:
#   ALF_DATA_PATH=D:/alfresco/acs-deployment/docker-compose/alf_data
ALF_DATA_PATH=/alf_data

# --- Local PostgreSQL (job tracking database) ---
# In Docker: use service name "local_db". For dev: use localhost.
LOCAL_DB_URL=postgresql://aes_user:aes_pass@local_db:5432/aes_tracking

# --- Redis (Celery broker) ---
REDIS_URL=redis://redis:6379/0

# --- Export output directory (relative to backend/) ---
EXPORT_DIR=./exports

# Remote SMB-backed Alfresco contentstore is sensitive to parallel reads.
COPY_CONCURRENCY=1

# --- Alfresco REST API (optional fallback) ---
ALFRESCO_API_URL=http://172.31.12.119:8080/alfresco
ALFRESCO_USER=admin
ALFRESCO_PASS=ITG646
